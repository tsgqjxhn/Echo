APP_ENV=development
PUBLIC_BASE_URL=http://127.0.0.1:8000

# 可选：设置后所有 API（除 /health、/docs）需 Authorization: Bearer <token>
API_TOKEN=

# SQLite by default. Replace with PostgreSQL in production if needed.
DATABASE_URL=sqlite:///./storage/app.db

# Backend-managed providers
LLM_PROVIDER=mock
TTS_PROVIDER=disabled
STT_PROVIDER=disabled

# OpenAI-compatible runtime config
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=alloy
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# 上传与导入大小限制（字节）
MAX_UPLOAD_BYTES=20971520
MAX_IMPORT_JSON_BYTES=52428800
